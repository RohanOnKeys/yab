# ==============================
# Model
# ==============================

class TabularClassifier(nn.Module):
    """Simple MLP for tabular classification."""
    
    def __init__(self, input_features, num_classes, hidden_dims, dropout):
        super(TabularClassifier, self).__init__()
        
        layers = []
        prev_dim = input_features
        
        # Hidden layers
        for hidden_dim in hidden_dims:
            layers.append(nn.Linear(prev_dim, hidden_dim))
            layers.append(nn.ReLU())
            layers.append(nn.Dropout(dropout))
            prev_dim = hidden_dim
        
        # Output layer
        layers.append(nn.Linear(prev_dim, num_classes))
        
        self.network = nn.Sequential(*layers)
    
    def forward(self, x):
        return self.network(x)


# ==============================
# Trainer
# ==============================

class Trainer:
    """Training abstraction with scheduler, early stopping, and checkpoints."""
    
    def __init__(self, model, train_loader, val_loader, criterion, optimizer, config):
        self.model = model
        self.train_loader = train_loader
        self.val_loader = val_loader
        self.criterion = criterion
        self.optimizer = optimizer
        self.config = config
        
        # Early stopping
        self.best_val_loss = float('inf')
        self.patience_counter = 0
        
        # Scheduler
        self.scheduler = self._setup_scheduler()
        
        # Metrics history
        self.history = {
            'train_loss': [],
            'train_acc': [],
            'val_loss': [],
            'val_acc': []
        }
        
        # Create checkpoint directory
        os.makedirs(self.config.CHECKPOINT_DIR, exist_ok=True)
    
    def _setup_scheduler(self):
        """Setup learning rate scheduler."""
        if self.config.SCHEDULER == "step":
            return optim.lr_scheduler.StepLR(
                self.optimizer, step_size=30, gamma=0.1
            )
        elif self.config.SCHEDULER == "cosine":
            return optim.lr_scheduler.CosineAnnealingLR(
                self.optimizer, T_max=self.config.EPOCHS
            )
        elif self.config.SCHEDULER == "plateau":
            return optim.lr_scheduler.ReduceLROnPlateau(
                self.optimizer, mode='min', patience=5, factor=0.5
            )
        else:
            return None
    
    def train_epoch(self):
        """Train for one epoch."""
        self.model.train()
        running_loss = 0.0
        correct = 0
        total = 0
        
        for features, labels in self.train_loader:
            features, labels = features.to(self.config.DEVICE), labels.to(self.config.DEVICE)
            
            # Forward pass
            outputs = self.model(features)
            loss = self.criterion(outputs, labels)
            
            # Backward pass and optimize
            self.optimizer.zero_grad()
            loss.backward()
            self.optimizer.step()
            
            # Update scheduler if not plateau
            if self.scheduler and self.config.SCHEDULER != "plateau":
                self.scheduler.step()
            
            # Statistics
            running_loss += loss.item()
            _, predicted = torch.max(outputs.data, 1)
            total += labels.size(0)
            correct += (predicted == labels).sum().item()
        
        epoch_loss = running_loss / len(self.train_loader)
        epoch_acc = 100 * correct / total
        
        return epoch_loss, epoch_acc
    
    def validate(self):
        """Validate the model."""
        self.model.eval()
        running_loss = 0.0
        correct = 0
        total = 0
        
        with torch.no_grad():
            for features, labels in self.val_loader:
                features, labels = features.to(self.config.DEVICE), labels.to(self.config.DEVICE)
                
                # Forward pass
                outputs = self.model(features)
                loss = self.criterion(outputs, labels)
                
                # Statistics
                running_loss += loss.item()
                _, predicted = torch.max(outputs.data, 1)
                total += labels.size(0)
                correct += (predicted == labels).sum().item()
        
        epoch_loss = running_loss / len(self.val_loader)
        epoch_acc = 100 * correct / total
        
        return epoch_loss, epoch_acc
    
    def save_checkpoint(self, epoch, val_loss, is_best=False):
        """Save model checkpoint."""
        checkpoint = {
            'epoch': epoch,
            'model_state_dict': self.model.state_dict(),
            'optimizer_state_dict': self.optimizer.state_dict(),
            'scheduler_state_dict': self.scheduler.state_dict() if self.scheduler else None,
            'val_loss': val_loss,
            'history': self.history
        }
        
        if is_best:
            path = os.path.join(self.config.CHECKPOINT_DIR, 'best_model.pth')
            torch.save(checkpoint, path)
            print(f"Saved best model to {path}")
        else:
            path = os.path.join(self.config.CHECKPOINT_DIR, f'checkpoint_epoch_{epoch}.pth')
            torch.save(checkpoint, path)
    
    def early_stopping_check(self, val_loss):
        """Check if training should stop early."""
        if val_loss < self.best_val_loss:
            self.best_val_loss = val_loss
            self.patience_counter = 0
            return False
        else:
            self.patience_counter += 1
            if self.patience_counter >= self.config.PATIENCE:
                print(f"Early stopping triggered after {self.config.PATIENCE} epochs without improvement.")
                return True
            return False
    
    def predict(self, features):
        """Make prediction on a single sample."""
        self.model.eval()
        with torch.no_grad():
            features = torch.FloatTensor(features).to(self.config.DEVICE)
            features = features.unsqueeze(0)  # Add batch dimension
            outputs = self.model(features)
            _, predicted = torch.max(outputs, 1)
            return predicted.item()
    
    def fit(self):
        """Train the model with early stopping and checkpointing."""
        print(f"Training on {self.config.DEVICE}")
        print(f"Input features: {self.config.INPUT_FEATURES}")
        print(f"Hidden dimensions: {self.config.HIDDEN_DIMS}")
        print(f"Num classes: {self.config.NUM_CLASSES}")
        print(f"Batch size: {self.config.BATCH_SIZE}")
        print(f"Epochs: {self.config.EPOCHS}")
        print(f"Scheduler: {self.config.SCHEDULER}")
        print(f"Early stopping patience: {self.config.PATIENCE}")
        print("-" * 60)
        
        for epoch in range(self.config.EPOCHS):
            # Train
            train_loss, train_acc = self.train_epoch()
            
            # Validate
            val_loss, val_acc = self.validate()
            
            # Update history
            self.history['train_loss'].append(train_loss)
            self.history['train_acc'].append(train_acc)
            self.history['val_loss'].append(val_loss)
            self.history['val_acc'].append(val_acc)
            
            # Update scheduler for plateau
            if self.scheduler and self.config.SCHEDULER == "plateau":
                self.scheduler.step(val_loss)
            
            # Logging
            print(f"Epoch [{epoch+1}/{self.config.EPOCHS}]")
            print(f"Train Loss: {train_loss:.4f}, Train Acc: {train_acc:.2f}%")
            print(f"Val Loss: {val_loss:.4f}, Val Acc: {val_acc:.2f}%")
            
            if self.scheduler:
                current_lr = self.optimizer.param_groups[0]['lr']
                print(f"Learning Rate: {current_lr:.6f}")
            
            print("-" * 60)
            
            # Save checkpoint
            is_best = val_loss < self.best_val_loss
            if self.config.SAVE_BEST and is_best:
                self.save_checkpoint(epoch, val_loss, is_best=True)
            
            # Early stopping check
            if self.early_stopping_check(val_loss):
                break
        
        print("Training complete!")
        print(f"Best validation loss: {self.best_val_loss:.4f}")


