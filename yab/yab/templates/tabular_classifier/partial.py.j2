def main():
    # Initialize model
    model = TabularClassifier(
        Config.INPUT_FEATURES,
        Config.NUM_CLASSES,
        Config.HIDDEN_DIMS,
        Config.DROPOUT
    ).to(Config.DEVICE)
    
    # Loss function
    criterion = nn.CrossEntropyLoss()
    
    # Optimizer
    optimizer = optim.Adam(
        model.parameters(),
        lr=Config.LR,
        weight_decay=Config.WEIGHT_DECAY
    )
    
    # Initialize trainer
    trainer = Trainer(
        model=model,
        train_loader=train_loader,
        val_loader=val_loader,
        criterion=criterion,
        optimizer=optimizer,
        config=Config
    )
    
    # Train
    trainer.fit()


if __name__ == "__main__":
    main()