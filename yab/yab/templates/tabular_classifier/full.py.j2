class Trainer:
    """Production-ready training abstraction with AMP, TensorBoard, and checkpointing."""
    
    def __init__(self, model, train_loader, val_loader, criterion, optimizer, scheduler, config):
        self.model = model
        self.train_loader = train_loader
        self.val_loader = val_loader
        self.criterion = criterion
        self.optimizer = optimizer
        self.scheduler = scheduler
        self.config = config
        
        # Early stopping
        self.best_val_loss = float('inf')
        self.patience_counter = 0
        
        # AMP
        self.scaler = GradScaler() if config.MIXED_PRECISION else None
        
        # TensorBoard
        self.writer = SummaryWriter(config.LOG_DIR)
        
        # Metrics history
        self.history = {
            'train_loss': [],
            'train_acc': [],
            'val_loss': [],
            'val_acc': []
        }
        
        # Training state
        self.start_epoch = 0
        
        # Create checkpoint directory
        os.makedirs(self.config.CHECKPOINT_DIR, exist_ok=True)
        
        # Resume from checkpoint if specified
        if self.config.RESUME_FROM:
            self.load_checkpoint(self.config.RESUME_FROM)
    
    def train_epoch(self, epoch):
        """Train for one epoch with progress bar and AMP."""
        self.model.train()
        running_loss = 0.0
        correct = 0
        total = 0
        
        # Progress bar
        pbar = tqdm(self.train_loader, desc=f"Epoch {epoch+1}/{self.config.EPOCHS} [Train]")
        
        for features, labels in pbar:
            features, labels = features.to(self.config.DEVICE), labels.to(self.config.DEVICE)
            
            self.optimizer.zero_grad()
            
            if self.config.MIXED_PRECISION:
                # AMP forward pass
                with autocast():
                    outputs = self.model(features)
                    loss = self.criterion(outputs, labels)
                
                # AMP backward pass
                self.scaler.scale(loss).backward()
                
                # Gradient clipping
                if self.config.GRADIENT_CLIPPING > 0:
                    self.scaler.unscale_(self.optimizer)
                    torch.nn.utils.clip_grad_norm_(
                        self.model.parameters(),
                        self.config.GRADIENT_CLIPPING
                    )
                
                self.scaler.step(self.optimizer)
                self.scaler.update()
            else:
                # Standard forward pass
                outputs = self.model(features)
                loss = self.criterion(outputs, labels)
                
                # Standard backward pass
                loss.backward()
                
                # Gradient clipping
                if self.config.GRADIENT_CLIPPING > 0:
                    torch.nn.utils.clip_grad_norm_(
                        self.model.parameters(),
                        self.config.GRADIENT_CLIPPING
                    )
                
                self.optimizer.step()
            
            # Update scheduler if not plateau
            if self.scheduler and self.config.SCHEDULER != "plateau":
                self.scheduler.step()
            
            # Statistics
            running_loss += loss.item()
            _, predicted = torch.max(outputs.data, 1)
            total += labels.size(0)
            correct += (predicted == labels).sum().item()
            
            # Update progress bar
            pbar.set_postfix({
                'loss': f'{loss.item():.4f}',
                'acc': f'{100 * correct / total:.2f}%'
            })
        
        epoch_loss = running_loss / len(self.train_loader)
        epoch_acc = 100 * correct / total
        
        return epoch_loss, epoch_acc
    
    def validate(self, epoch):
        """Validate the model with progress bar."""
        self.model.eval()
        running_loss = 0.0
        correct = 0
        total = 0
        
        # Progress bar
        pbar = tqdm(self.val_loader, desc=f"Epoch {epoch+1}/{self.config.EPOCHS} [Val]")
        
        with torch.no_grad():
            for features, labels in pbar:
                features, labels = features.to(self.config.DEVICE), labels.to(self.config.DEVICE)
                
                if self.config.MIXED_PRECISION:
                    with autocast():
                        outputs = self.model(features)
                        loss = self.criterion(outputs, labels)
                else:
                    outputs = self.model(features)
                    loss = self.criterion(outputs, labels)
                
                # Statistics
                running_loss += loss.item()
                _, predicted = torch.max(outputs.data, 1)
                total += labels.size(0)
                correct += (predicted == labels).sum().item()
                
                # Update progress bar
                pbar.set_postfix({
                    'loss': f'{loss.item():.4f}',
                    'acc': f'{100 * correct / total:.2f}%'
                })
        
        epoch_loss = running_loss / len(self.val_loader)
        epoch_acc = 100 * correct / total
        
        return epoch_loss, epoch_acc
    
    def save_checkpoint(self, epoch, val_loss, is_best=False):
        """Save model checkpoint."""
        checkpoint = {
            'epoch': epoch,
            'model_state_dict': self.model.state_dict(),
            'optimizer_state_dict': self.optimizer.state_dict(),
            'scheduler_state_dict': self.scheduler.state_dict() if self.scheduler else None,
            'val_loss': val_loss,
            'history': self.history,
            'best_val_loss': self.best_val_loss
        }
        
        if self.scaler:
            checkpoint['scaler_state_dict'] = self.scaler.state_dict()
        
        if is_best:
            path = os.path.join(self.config.CHECKPOINT_DIR, 'best_model.pth')
            torch.save(checkpoint, path)
            print(f"Saved best model to {path}")
        else:
            path = os.path.join(self.config.CHECKPOINT_DIR, f'checkpoint_epoch_{epoch}.pth')
            torch.save(checkpoint, path)
    
    def load_checkpoint(self, checkpoint_path):
        """Load model checkpoint for resuming training."""
        print(f"Loading checkpoint from {checkpoint_path}")
        checkpoint = torch.load(checkpoint_path, map_location=self.config.DEVICE)
        
        self.model.load_state_dict(checkpoint['model_state_dict'])
        self.optimizer.load_state_dict(checkpoint['optimizer_state_dict'])
        
        if checkpoint.get('scheduler_state_dict') and self.scheduler:
            self.scheduler.load_state_dict(checkpoint['scheduler_state_dict'])
        
        if checkpoint.get('scaler_state_dict') and self.scaler:
            self.scaler.load_state_dict(checkpoint['scaler_state_dict'])
        
        self.start_epoch = checkpoint['epoch'] + 1
        self.best_val_loss = checkpoint.get('best_val_loss', float('inf'))
        self.history = checkpoint.get('history', {
            'train_loss': [],
            'train_acc': [],
            'val_loss': [],
            'val_acc': []
        })
        
        print(f"Resumed from epoch {self.start_epoch}")
        print(f"Best validation loss: {self.best_val_loss:.4f}")
    
    def early_stopping_check(self, val_loss):
        """Check if training should stop early."""
        if val_loss < self.best_val_loss:
            self.best_val_loss = val_loss
            self.patience_counter = 0
            return False
        else:
            self.patience_counter += 1
            if self.patience_counter >= self.config.PATIENCE:
                print(f"Early stopping triggered after {self.config.PATIENCE} epochs without improvement.")
                return True
            return False
    
    def predict(self, features):
        """Make prediction on a single sample."""
        self.model.eval()
        with torch.no_grad():
            features = torch.FloatTensor(features).to(self.config.DEVICE)
            features = features.unsqueeze(0)  # Add batch dimension
            
            if self.config.MIXED_PRECISION:
                with autocast():
                    outputs = self.model(features)
            else:
                outputs = self.model(features)
            
            _, predicted = torch.max(outputs, 1)
            return predicted.item()
    
    def fit(self):
        """Train the model with full production features."""
        print(f"Training on {self.config.DEVICE}")
        print(f"Input features: {self.config.INPUT_FEATURES}")
        print(f"Hidden dimensions: {self.config.HIDDEN_DIMS}")
        print(f"Num classes: {self.config.NUM_CLASSES}")
        print(f"Batch size: {self.config.BATCH_SIZE}")
        print(f"Epochs: {self.config.EPOCHS}")
        print(f"Scheduler: {self.config.SCHEDULER}")
        print(f"Early stopping patience: {self.config.PATIENCE}")
        print(f"Mixed Precision: {self.config.MIXED_PRECISION}")
        print(f"Gradient Clipping: {self.config.GRADIENT_CLIPPING}")
        print(f"TensorBoard logs: {self.config.LOG_DIR}")
        print("-" * 70)
        
        for epoch in range(self.start_epoch, self.config.EPOCHS):
            # Train
            train_loss, train_acc = self.train_epoch(epoch)
            
            # Validate
            val_loss, val_acc = self.validate(epoch)
            
            # Update history
            self.history['train_loss'].append(train_loss)
            self.history['train_acc'].append(train_acc)
            self.history['val_loss'].append(val_loss)
            self.history['val_acc'].append(val_acc)
            
            # Log to TensorBoard
            self.writer.add_scalar('Loss/train', train_loss, epoch)
            self.writer.add_scalar('Loss/val', val_loss, epoch)
            self.writer.add_scalar('Accuracy/train', train_acc, epoch)
            self.writer.add_scalar('Accuracy/val', val_acc, epoch)
            
            if self.scheduler is not None:
                current_lr = self.optimizer.param_groups[0]['lr']
                self.writer.add_scalar('Learning_Rate', current_lr, epoch)
                
                if self.config.SCHEDULER == "plateau":
                    self.scheduler.step(val_loss)
            
            # Print summary
            print(f"\nEpoch [{epoch+1}/{self.config.EPOCHS}] Summary:")
            print(f"  Train Loss: {train_loss:.4f}, Train Acc: {train_acc:.2f}%")
            print(f"  Val Loss: {val_loss:.4f}, Val Acc: {val_acc:.2f}%")
            
            if self.scheduler is not None:
                current_lr = self.optimizer.param_groups[0]['lr']
                print(f"  Learning Rate: {current_lr:.6f}")
            
            print("-" * 70)
            
            # Save checkpoint
            is_best = val_loss < self.best_val_loss
            if self.config.SAVE_BEST and is_best:
                self.save_checkpoint(epoch, val_loss, is_best=True)
            else:
                self.save_checkpoint(epoch, val_loss, is_best=False)
            
            # Early stopping check
            if self.early_stopping_check(val_loss):
                break
        
        self.writer.close()
        print("\nTraining complete!")
        print(f"Best validation loss: {self.best_val_loss:.4f}")
        print(f"TensorBoard logs saved to: {self.config.LOG_DIR}")


