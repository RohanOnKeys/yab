def main():
    # Initialize model
    model = TextClassifier(
        Config.NUM_CLASSES,
        Config.MODEL_NAME
    ).to(Config.DEVICE)
    
    # Loss function
    criterion = nn.CrossEntropyLoss()
    
    # Optimizer
    optimizer = optim.AdamW(
        model.parameters(),
        lr=Config.LR,
        weight_decay=Config.WEIGHT_DECAY
    )
    
    # Initialize trainer
    trainer = Trainer(
        model=model,
        train_loader=train_loader,
        val_loader=val_loader,
        criterion=criterion,
        optimizer=optimizer,
        config=Config
    )
    
    # Train
    trainer.fit()


if __name__ == "__main__":
    main()