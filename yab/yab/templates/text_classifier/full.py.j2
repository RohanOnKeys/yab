def main():
    # Initialize trainer
    trainer = Trainer(
        model=model,
        train_loader=train_loader,
        val_loader=val_loader,
        criterion=criterion,
        optimizer=optimizer,
        scheduler=scheduler,
        config=Config
    )
    
    # Train
    trainer.fit()


if __name__ == "__main__":
    main()